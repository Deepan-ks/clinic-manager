<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd">

    <changeSet id="001-create-bill-sequence" author="deepan">

        <createTable tableName="bill_sequence">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="month_year" type="VARCHAR(7)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="current_value" type="INT">
                <constraints nullable="false"/>
            </column>

        </createTable>

    </changeSet>

    <changeSet id="002-unique-bill-sequence-month" author="deepan">

        <addUniqueConstraint
                tableName="bill_sequence"
                columnNames="month_year"
                constraintName="uk_bill_sequence_month_year"/>

    </changeSet>

</databaseChangeLog>