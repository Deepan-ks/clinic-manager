<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd">

    <changeSet id="001-add-discount-columns" author="deepan">

        <addColumn tableName="bills">
            <column name="discount_amount" type="numeric(10,2)" defaultValueNumeric="0"/>
        </addColumn>

        <addColumn tableName="bills">
            <column name="discount_percent" type="numeric(5,2)" defaultValueNumeric="0"/>
        </addColumn>

    </changeSet>
</databaseChangeLog>